# =============================================================================
#  Navio — credential template.  COPY this file to ".env" and fill in the values.
#
#    cp .env.example .env        (Mac/Linux)
#    Copy-Item .env.example .env (Windows PowerShell)
#
#  ".env" is git-ignored and must NEVER be committed or shared in chat/email.
#
#  WHICH FILE DO I NEED?
#   - Local dev / Docker Compose on a server  -> fill THIS .env, run normally.
#   - Google Cloud Run                        -> the two SECRET values below go
#     into Secret Manager (NOT .env); everything else goes into
#     backend/cloudrun.env.yaml.  See DEPLOY.md for the exact commands.
# =============================================================================

# --- SECRET 1: Azure OpenAI (pays for every reply) --------------------------
# Get from the Azure portal -> your OpenAI resource -> "Keys and Endpoint".
AZURE_AI_CHATBOT_API_KEY=PASTE_YOUR_AZURE_OPENAI_KEY_HERE
AZURE_AI_CHATBOT_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/openai/v1
AZURE_AI_CHATBOT_DEPLOYMENT_NAME=gpt-4.1

# --- SECRET 2: Supabase (stores bot config + consent-gated chat log) --------
# Get from Supabase -> Project Settings -> API.  The service-role key bypasses
# row-level security: keep it secret, never put it in the frontend.
# Run backend/schema.sql once in the Supabase SQL editor to create the tables.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# ============================================================================
#  Everything below is non-secret config. The defaults are fine to leave as-is.
# ============================================================================

# Which websites may embed the chatbot (CORS allowlist, comma-separated).
ALLOWED_ORIGINS=https://sportnavi.de,https://www.sportnavi.de

# Per-visitor rate limits (stop a single spammer from running up the bill).
RATE_LIMIT_PER_MIN=15
RATE_LIMIT_PER_DAY=300

# Input size caps.
MAX_MESSAGE_CHARS=2000
MAX_HISTORY_TURNS=10

# Model output: reply length + creativity (0 = factual, 1 = playful).
MAX_TOKENS=800
TEMPERATURE=0.4

# How long config is cached before re-reading Supabase (seconds).
CONFIG_TTL_SEC=30

# --- Bot protection (turn ON only when the site is public) ------------------
# Cloudflare Turnstile secret. Empty = OFF (fine for dev). Paste the Secret Key
# at go-live to require an "are you human?" check before chatting.
TURNSTILE_SECRET=
# Long random string used to sign visitor session tokens. Required when Turnstile
# is on. Generate one with:  openssl rand -hex 32
SESSION_SECRET=
SESSION_TTL_MIN=30

# Salt for hashing visitor IPs in the log (we never store a raw IP).
# Empty = falls back to SESSION_SECRET. Set any long random string in production.
IP_HASH_SALT=

# --- Admin auth: Clerk (recommended) ----------------------------------------
# When CLERK_ISSUER is set, the config-write endpoints (/api/config/*) require a
# signed-in Clerk user whose VERIFIED email domain is on ADMIN_EMAIL_DOMAINS.
# CLERK_ISSUER is your Clerk Frontend API origin (Clerk dashboard -> API Keys, or
# decode your pk_ key). CLERK_SECRET_KEY (sk_...) is used to look up the user's
# email — KEEP IT SECRET (Secret Manager on Cloud Run, never the frontend).
CLERK_ISSUER=https://normal-joey-58.clerk.accounts.dev
CLERK_SECRET_KEY=PASTE_YOUR_CLERK_SECRET_KEY_HERE
ADMIN_EMAIL_DOMAINS=sportnavi.de,ncr4ailab.de
# NOTE: the Clerk PUBLISHABLE key is NOT set here. The browser needs it, so it
# lives on the frontend side: frontend/.env (dev) and frontend/.env.production
# (committed, used by both `docker compose` and the Cloud Run frontend build).

# Legacy fallback: shared password for /api/config/* used ONLY when CLERK_ISSUER
# is empty. Empty = open (dev only).
ADMIN_TOKEN=

# --- Shared rate-limit store (only when running MORE THAN ONE instance) -----
# Empty = single-process, in-memory counters (correct for Cloud Run max-instances=1
# and for `uvicorn` run directly). Docker Compose sets this to the bundled Redis
# automatically. Set to a redis:// URL only when you scale past one instance.
REDIS_URL=

# --- Docker Compose only (ignored on Cloud Run) -----------------------------
# Public domain Caddy issues a free HTTPS cert for. Use ":80" for local testing.
NAVIO_DOMAIN=:80
# Number of app workers (rule of thumb: ~2 x CPU cores).
WORKERS=2
