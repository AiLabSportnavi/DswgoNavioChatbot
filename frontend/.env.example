# =============================================================================
#  Frontend (Vite) env template. COPY to ".env" and fill in.
#    Copy-Item .env.example .env   (Windows PowerShell)
#    cp .env.example .env          (Mac/Linux)
#
#  ".env" is git-ignored. Only PUBLISHABLE / public values belong here — anything
#  Vite exposes (the VITE_* prefix) ships to the browser. NEVER put a secret
#  (Clerk sk_..., Azure, Supabase service-role) in this file.
# =============================================================================

# Clerk publishable key — safe in the browser (it only identifies your Clerk app).
# Clerk dashboard -> API Keys -> "Publishable key". pk_test_... in dev, pk_live_... in prod.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_PASTE_YOUR_CLERK_PUBLISHABLE_KEY_HERE

# Backend origin in production (e.g. https://navio.sportnavi.de). Leave EMPTY in
# local dev — Vite proxies /api to the backend (see vite.config.ts).
VITE_NAVIO_API=
