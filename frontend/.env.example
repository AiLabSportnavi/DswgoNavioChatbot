# =============================================================================
#  Frontend (Vite) env template. COPY to ".env" and fill in.
#    Copy-Item .env.example .env   (Windows PowerShell)
#    cp .env.example .env          (Mac/Linux)
#
#  ".env" is git-ignored. Only PUBLISHABLE / public values belong here — anything
#  Vite exposes (the VITE_* prefix) ships to the browser. NEVER put a secret
#  (Clerk sk_..., the Azure key, DATABASE_URL) in this file — those live on the backend.
# =============================================================================

# Clerk publishable key — safe in the browser (it only identifies your Clerk app).
# Clerk dashboard -> API Keys -> "Publishable key". pk_test_... in dev, pk_live_... in prod.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_PASTE_YOUR_CLERK_PUBLISHABLE_KEY_HERE

# Backend origin. Leave EMPTY in local dev — Vite proxies /api to the backend on
# :8000 (see vite.config.ts), so the browser stays same-origin (no CORS).
# In PRODUCTION set this to the backend's absolute URL (e.g. https://navio-xxxx.run.app
# or your Vercel backend URL) — every prod host (Vercel AND the nginx container) now
# calls the backend directly at this URL, and the backend allows it via ALLOWED_ORIGINS.
# The Navio Plus contact form also posts here (backend POST /api/contact → Salesforce).
VITE_NAVIO_API=
