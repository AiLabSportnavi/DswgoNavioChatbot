# =============================================================================
#  Navio — one-command deploy settings for  ./deploy.ps1
#
#  COPY this file to "deploy.env" and fill in your values:
#      Copy-Item deploy.env.example deploy.env
#
#  "deploy.env" is git-ignored — your secrets never get committed.
#  Rules: one KEY=value per line, NO quotes around values, no spaces around "=".
# =============================================================================

# ── Google Cloud ────────────────────────────────────────────────────────────
GCP_PROJECT=navio-sportnavi-prod
GCP_REGION=europe-west3

# ── Cloud Run service names (these also decide the URLs) ─────────────────────
# Optional — defaults shown. Rules: lowercase letters/numbers/hyphens, start with
# a letter, max 63 chars. NOTE: changing a name creates a NEW service with a NEW
# URL; the old one stays until you delete it (gcloud run services delete <name>).
BACKEND_SERVICE=navio
FRONTEND_SERVICE=navio-frontend

# ── Secrets (the script puts these in Google Secret Manager — never in git) ──
# Azure OpenAI key — Azure portal → your OpenAI resource → "Keys and Endpoint".
AZURE_AI_CHATBOT_API_KEY=

# Postgres connection string — use the POOLER, not the direct db.<ref>.supabase.co
# host (Cloud Run can't reach that one). Copy it from Supabase → Connect:
#   Session pooler   (5432):  postgresql://postgres.<ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres
#   Transaction pooler (6543): same but :6543   (either works — this app handles both)
DATABASE_URL=

# Clerk SECRET key (admin login) — starts with sk_
CLERK_SECRET_KEY=

# ── Frontend (PUBLIC — safe in the browser) ─────────────────────────────────
# Clerk PUBLISHABLE key — starts with pk_. OPTIONAL: leave blank to keep the one
# already in frontend/.env.production.
VITE_CLERK_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Non-secret backend config (Azure endpoint, model, Clerk issuer, admin email
# domains, the base ALLOWED_ORIGINS for your real domains) lives in
# backend/cloudrun.env.yaml — edit that once. The script automatically adds the
# frontend's Cloud Run URL to ALLOWED_ORIGINS for you, so chat works right away.
# -----------------------------------------------------------------------------
