# =============================================================================
#  Navio — Cloud Run deploy settings for  ./deploy.ps1
#
#  COPY this file to "deploy.env" and fill in your values:
#      Copy-Item deploy.env.example deploy.env
#
#  "deploy.env" is git-ignored — your settings never get committed.
#  Rules: one KEY=value per line, NO quotes around values, no spaces around "=".
#
#  ── WHERE DO THE SECRETS GO? ────────────────────────────────────────────────
#  Backend secrets (Azure key, DATABASE_URL, Clerk secret, Salesforce) live in
#  ONE place: backend/.env  — the SAME file local dev and Docker use. deploy.ps1
#  reads them from there automatically, so you do NOT repeat them here.
#
#  This file only needs the Cloud-Run-specific settings below (which GCP project /
#  region to deploy into). Anything you DO put here OVERRIDES backend/.env — handy
#  if production should differ from local (e.g. a prod DATABASE_URL); see the
#  optional override block at the bottom.
# =============================================================================

# ── Google Cloud (REQUIRED) ─────────────────────────────────────────────────
GCP_PROJECT=my-navio-project
GCP_REGION=europe-west3

# ── Cloud Run service names (optional — defaults shown; they also decide URLs) ─
# Rules: lowercase letters/numbers/hyphens, start with a letter, max 63 chars.
# Changing a name creates a NEW service with a NEW URL (the old one stays until
# you delete it: gcloud run services delete <name>).
BACKEND_SERVICE=navio
FRONTEND_SERVICE=navio-frontend

# -----------------------------------------------------------------------------
# OPTIONAL — production overrides. Uncomment a line ONLY to make production differ
# from backend/.env. Most teams leave this empty and keep everything in backend/.env.
#
#   # Use a different database in production than the one in backend/.env:
#   DATABASE_URL=postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
#   # Override a secret just for the cloud deploy:
#   AZURE_AI_CHATBOT_API_KEY=
#   CLERK_SECRET_KEY=
#   SALESFORCE_CLIENT_ID=
#   SALESFORCE_CLIENT_SECRET=
#
#   # Use a different public Clerk key for the production frontend build
#   # (otherwise the one in frontend/.env.production is used):
#   VITE_CLERK_PUBLISHABLE_KEY=
# -----------------------------------------------------------------------------
