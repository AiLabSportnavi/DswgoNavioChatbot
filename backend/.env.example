# =============================================================================
#  Navio BACKEND env template.  Copy to "backend/.env" and fill in the values.
#
#    Copy-Item backend\.env.example backend\.env   (Windows PowerShell, from repo root)
#    cp backend/.env.example backend/.env          (Mac/Linux, from repo root)
#
#  "backend/.env" is git-ignored and must NEVER be committed or shared in chat/email.
#
#  WHICH FILE DO I NEED?
#   - Local dev (uvicorn)   -> copy this to backend/.env and fill it in.
#   - Google Cloud Run      -> the SECRET values below go into Secret Manager
#     (NOT .env); everything else goes into backend/cloudrun.env.yaml.
#   - Vercel                -> set the same keys in Project -> Settings ->
#     Environment Variables (no .env file is uploaded).
#  See DEPLOY.md and backend/README.md for the exact steps per host.
# =============================================================================

# --- SECRET 1: Azure OpenAI (pays for every reply) --------------------------
# Get from the Azure portal -> your OpenAI resource -> "Keys and Endpoint".
AZURE_AI_CHATBOT_API_KEY=PASTE_YOUR_AZURE_OPENAI_KEY_HERE
AZURE_AI_CHATBOT_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/openai/v1
AZURE_AI_CHATBOT_DEPLOYMENT_NAME=gpt-4.1

# --- SECRET 2: Postgres database (stores bot config + consent-gated chat log) -
# Standard PostgreSQL connection string. Supabase and Azure are BOTH plain Postgres
# — pick either and just set this one URL (no code change). Empty = no DB (config
# falls back to the on-disk prompts/SYSTEM_PROMPT.md). Run backend/sql/schema.sql
# once against the server to create the tables (use a direct port 5432 for that).
#
# Use a connection POOLER port for the app so a serverless / multi-instance backend
# never exhausts Postgres connections (the app already disables prepared statements
# so a transaction pooler works fine):
#
#   Supabase  (transaction pooler, 6543 — best for Vercel/serverless):
#     postgresql://postgres.<project-ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres
#   Supabase  (session pooler, 5432 — fine for Cloud Run max-instances=1):
#     postgresql://postgres.<project-ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres
#   Azure DB for PostgreSQL (PgBouncer 6432, keep sslmode=require):
#     postgresql://navioadmin:PASSWORD@navio-pg-xxxx.postgres.database.azure.com:6432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.<project-ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- SECRET 3: Salesforce (Navio Plus contact form → CaseHandler flow) ------
# The contact form posts to OUR backend, which calls Salesforce server-side (the
# client_id/secret must NEVER reach the browser). Get both from Bitwarden:
# "Website API Client ID und Secret". Empty = contact form runs in demo/simulate
# mode (logs the request, returns success) so the UI stays testable without creds.
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# Non-secret Salesforce config (defaults match the Sportnavi org — change per env):
SALESFORCE_TOKEN_URL=https://sportnavi.my.salesforce.com/services/oauth2/token
SALESFORCE_INSTANCE_URL=https://sportnavi.my.salesforce.com
SALESFORCE_API_VERSION=v65.0
SALESFORCE_FLOW_API_NAME=CaseHandler

# --- Contact fallback email (used only if the Salesforce flow fails) --------
# If the flow returns isSuccess=false (or errors), the request is emailed here so
# it is never lost. Without SMTP_HOST it is logged at ERROR level instead.
CONTACT_FALLBACK_EMAIL=service@sportnavi.de
CONTACT_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true

# ============================================================================
#  Everything below is non-secret config. The defaults are fine to leave as-is.
# ============================================================================

# Which websites may embed the chatbot (CORS allowlist, comma-separated).
ALLOWED_ORIGINS=https://sportnavi.de,https://www.sportnavi.de

# Per-visitor rate limits (stop a single spammer from running up the bill).
RATE_LIMIT_PER_MIN=15
RATE_LIMIT_PER_DAY=300

# Input size caps.
MAX_MESSAGE_CHARS=2000
MAX_HISTORY_TURNS=10

# Model output: reply length + creativity (0 = factual, 1 = playful).
MAX_TOKENS=800
TEMPERATURE=0.4

# How long config is cached before re-reading the database (seconds).
CONFIG_TTL_SEC=30

# --- Bot protection (turn ON only when the site is public) ------------------
# Cloudflare Turnstile secret. Empty = OFF (fine for dev). Paste the Secret Key
# at go-live to require an "are you human?" check before chatting.
TURNSTILE_SECRET=
# Long random string used to sign visitor session tokens. Required when Turnstile
# is on. Generate one with:  openssl rand -hex 32
SESSION_SECRET=
SESSION_TTL_MIN=30

# Salt for hashing visitor IPs in the log (we never store a raw IP).
# Empty = falls back to SESSION_SECRET. Set any long random string in production.
IP_HASH_SALT=

# --- Admin auth: Clerk (recommended) ----------------------------------------
# When CLERK_ISSUER is set, the config-write endpoints (/api/config/*) require a
# signed-in Clerk user whose VERIFIED email domain is on ADMIN_EMAIL_DOMAINS.
# CLERK_ISSUER is your Clerk Frontend API origin (Clerk dashboard -> API Keys, or
# decode your pk_ key). CLERK_SECRET_KEY (sk_...) is used to look up the user's
# email — KEEP IT SECRET (Secret Manager on Cloud Run, never the frontend).
CLERK_ISSUER=https://normal-joey-58.clerk.accounts.dev
CLERK_SECRET_KEY=PASTE_YOUR_CLERK_SECRET_KEY_HERE
ADMIN_EMAIL_DOMAINS=sportnavi.de,ncr4ailab.de
# NOTE: the Clerk PUBLISHABLE key is NOT set here. The browser needs it, so it
# lives on the frontend side: frontend/.env (dev) and frontend/.env.production
# (committed; used by the Cloud Run / container frontend build). On Vercel set it
# in the project's Environment Variables instead.

# Legacy fallback: shared password for /api/config/* used ONLY when CLERK_ISSUER
# is empty. Empty = open (dev only).
ADMIN_TOKEN=

# --- Shared rate-limit store (serverless OR more than one instance) ---------
# Empty = single-process, in-memory counters (correct for Cloud Run max-instances=1
# and for `uvicorn` run directly). Set to a redis:// URL when you scale past one
# instance, OR on Vercel — serverless invocations are isolated, so in-memory
# counters don't add up there and you need a shared store (e.g. Upstash Redis) for
# per-IP rate limiting to actually work.
REDIS_URL=
